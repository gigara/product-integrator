+
+import { verify } from 'crypto';
+
+/**
+ * Verifies a detached cosign signature over `data` using a fixed public key.
+ *
+ * The CI signs the manifest with `cosign sign-blob --key …` (key-based, not keyless),
+ * producing a base64 signature; the matching public key (PEM) is embedded in the product
+ * as `wso2UpdatePublicKey` (base64-encoded to survive JSON). cosign uses ECDSA-P256 with a
+ * SHA-256 digest and DER-encoded signatures, but we also accept the IEEE-P1363 (raw r||s)
+ * encoding for robustness across signer versions.
+ */
+export function verifyDetachedSignature(data: Buffer, signatureBase64: string, publicKeyPem: string): boolean {
+	let signature: Buffer;
+	try {
+		signature = Buffer.from(signatureBase64.trim(), 'base64');
+	} catch {
+		return false;
+	}
+	if (signature.length === 0 || !publicKeyPem) {
+		return false;
+	}
+	for (const dsaEncoding of ['der', 'ieee-p1363'] as const) {
+		try {
+			if (verify('sha256', data, { key: publicKeyPem, dsaEncoding }, signature)) {
+				return true;
+			}
+		} catch {
+			// try the next encoding
+		}
+	}
+	return false;
+}
+
+/** Decodes the base64-encoded PEM public key embedded in the product configuration. */
+export function decodePublicKey(base64Pem: string | undefined): string | undefined {
+	if (!base64Pem) {
+		return undefined;
+	}
+	try {
+		const decoded = Buffer.from(base64Pem, 'base64').toString('utf8');
+		return decoded.includes('BEGIN PUBLIC KEY') ? decoded : undefined;
+	} catch {
+		return undefined;
+	}
+}
