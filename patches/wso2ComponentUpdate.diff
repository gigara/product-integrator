+//#region contribution
+
+class Wso2UpdateContribution extends Disposable implements IWorkbenchContribution {
+
+	static readonly ID = 'workbench.contrib.wso2Update';
+
+	private readonly availableContext: IContextKey<boolean>;
+	private lastNotifiedKey: string | undefined;
+
+	constructor(
+		@IWso2ComponentUpdateService private readonly updateService: IWso2ComponentUpdateService,
+		@INotificationService private readonly notificationService: INotificationService,
+		@ICommandService private readonly commandService: ICommandService,
+		@IContextKeyService contextKeyService: IContextKeyService,
+		@IHostService private readonly hostService: IHostService,
+		@INativeHostService private readonly nativeHostService: INativeHostService,
+		@IWorkbenchExtensionManagementService private readonly extensionManagementService: IWorkbenchExtensionManagementService,
+		@IActionViewItemService actionViewItemService: IActionViewItemService,
+		@IDialogService private readonly dialogService: IDialogService,
+		@ILogService private readonly logService: ILogService
+	) {
+		super();
+
+		this.availableContext = WSO2_UPDATES_AVAILABLE.bindTo(contextKeyService);
+
+		// Render the title-bar indicator as the prominent blue button.
+		this._register(actionViewItemService.register(
+			MenuId.TitleBarAdjacentCenter,
+			'wso2.updates.titleBarIndicator',
+			(action, options) => new Wso2UpdateIndicatorViewItem(action, options)
+		));
+
+		this._register(this.updateService.onStateChange(state => this.onStateChange(state)));
+		this.updateService.getState().then(state => this.onStateChange(state, true), err => this.logService.error('[wso2Update] getState failed', err));
+	}
+
+	private onStateChange(state: Wso2UpdateState, isInitial = false): void {
+		this.availableContext.set(state.type === Wso2UpdateStateType.UpdatesAvailable);
+
+		// The main process persists its state across a window reload. On the initial
+		// replay only sync the title-bar indicator — do NOT re-notify or re-install,
+		// otherwise a `Downloaded` state would re-prompt on every reload.
+		if (isInitial) {
+			return;
+		}
+
+		if (state.type === Wso2UpdateStateType.UpdatesAvailable) {
+			this.notifyAvailable(state);
+		} else if (state.type === Wso2UpdateStateType.Downloaded) {
+			void this.onDownloaded(state);
+		} else if (state.type === Wso2UpdateStateType.Error) {
+			this.notificationService.error(localize('wso2.updates.error', "Component update failed: {0}", state.message));
+		}
+	}
+
+	private notifyAvailable(state: Extract<Wso2UpdateState, { type: Wso2UpdateStateType.UpdatesAvailable }>): void {
+		// De-duplicate so background checks that keep returning the same set don't re-toast.
+		const key = [
+			...state.updates.map(u => `${u.id}@${u.toVersion}`),
+			state.appUpdate ? `app@${state.appUpdate.version}` : ''
+		].sort().join('|');
+		if (key === this.lastNotifiedKey) {
+			return;
+		}
+		this.lastNotifiedKey = key;
+
+		const names = state.updates.map(u => `${u.id} ${u.toVersion}`).join(', ');
+		const message = state.updates.length
+			? localize('wso2.updates.available', "Updates are available for WSO2 Integrator components: {0}", names)
+			: localize('wso2.updates.appAvailable', "A new version of WSO2 Integrator is available: {0}", state.appUpdate!.version);
+
+		const actions: IPromptChoice[] = [];
+		if (state.updates.length) {
+			actions.push({ label: localize('wso2.updates.updateAll', "Update All"), run: () => this.commandService.executeCommand('wso2.updates.applyAll') });
+		}
+		if (state.appUpdate) {
+			const appUpdate = state.appUpdate;
+			const label = isWindows ? localize('wso2.updates.updateApp', "Update") : localize('wso2.updates.downloadApp', "Download");
+			actions.push({ label, run: () => applyAppUpdate(this.updateService, this.dialogService, this.notificationService, appUpdate.version) });
+		}
+		actions.push({ label: localize('wso2.updates.showDetails', "Show Details"), run: () => this.commandService.executeCommand('wso2.updates.showComponents') });
+
+		this.notificationService.prompt(Severity.Info, message, actions);
+	}
+
+	private async onDownloaded(state: Extract<Wso2UpdateState, { type: Wso2UpdateStateType.Downloaded }>): Promise<void> {
+		let installed = 0;
+		let failed = 0;
+		for (const ext of state.stagedExtensions) {
+			try {
+				await this.extensionManagementService.install(URI.file(ext.vsixPath), { isBuiltin: true, pinned: true });
+				await this.updateService.recordExtensionInstalled(ext.id, ext.version);
+				installed++;
+			} catch (err) {
+				failed++;
+				this.logService.error(`[wso2Update] failed to install ${ext.id}@${ext.version}`, err);
+			}
+		}
+
+		if (failed > 0) {
+			this.notificationService.error(localize('wso2.updates.installFailed', "{0} component update(s) could not be installed. See the log (WSO2 Integrator) for details.", failed));
+		}
+
+		if (state.restartRequired) {
+			this.notificationService.prompt(Severity.Info, localize('wso2.updates.restart', "Restart WSO2 Integrator to finish updating components."), [
+				{ label: localize('wso2.updates.restartNow', "Restart"), run: () => this.nativeHostService.relaunch() }
+			]);
+		} else if (installed > 0) {
+			this.notificationService.prompt(Severity.Info, localize('wso2.updates.reload', "Reload the window to finish updating components."), [
+				{ label: localize('wso2.updates.reloadNow', "Reload Window"), run: () => this.hostService.reload() }
+			]);
+		}
+	}
+}
+
+registerWorkbenchContribution2(Wso2UpdateContribution.ID, Wso2UpdateContribution, WorkbenchPhase.Eventually);
+
+//#endregion
