+//#region commands
+
+class CheckForUpdatesAction extends Action2 {
+	constructor() {
+		super({
+			id: 'wso2.updates.check',
+			title: localize2('wso2.updates.check', "Check for Component Updates"),
+			category: CATEGORY,
+			f1: true
+		});
+	}
+	async run(accessor: ServicesAccessor): Promise<void> {
+		const updateService = accessor.get(IWso2ComponentUpdateService);
+		const notificationService = accessor.get(INotificationService);
+		await updateService.checkForUpdates(true);
+		const state = await updateService.getState();
+		if (state.type === Wso2UpdateStateType.Idle) {
+			notificationService.info(localize('wso2.updates.upToDate', "WSO2 Integrator components are up to date."));
+		} else if (state.type === Wso2UpdateStateType.Error) {
+			notificationService.error(localize('wso2.updates.checkError', "Checking for component updates failed: {0}", state.message));
+		}
+	}
+}
+
+/**
+ * Applies a core-app update. On Windows this confirms, then downloads + silently installs the
+ * editor-only update MSI and restarts (§D8). On macOS/Linux it hands off to the download flow.
+ */
+async function applyAppUpdate(
+	updateService: IWso2ComponentUpdateService,
+	dialogService: IDialogService,
+	notificationService: INotificationService,
+	version: string
+): Promise<void> {
+	if (!isWindows) {
+		await updateService.downloadAppInstaller();
+		return;
+	}
+	const { confirmed } = await dialogService.confirm({
+		message: localize("wso2.updates.appConfirm", "Update WSO2 Integrator to {0}?", version),
+		detail: localize("wso2.updates.appConfirmDetail", "The update will be downloaded and installed, then WSO2 Integrator will restart."),
+		primaryButton: localize("wso2.updates.appConfirmYes", "Update and Restart")
+	});
+	if (!confirmed) {
+		return;
+	}
+	const progress = notificationService.notify({
+		severity: Severity.Info,
+		message: localize("wso2.updates.appDownloading", "Downloading the WSO2 Integrator update…"),
+		sticky: true
+	});
+	try {
+		await updateService.applyAppUpdate();
+	} catch (err) {
+		notificationService.error(localize("wso2.updates.appFailed", "Failed to install the WSO2 Integrator update: {0}", String(err)));
+	} finally {
+		progress.close();
+	}
+}
+
+class UpdateAllAction extends Action2 {
+	constructor() {
+		super({
+			id: 'wso2.updates.applyAll',
+			title: localize2('wso2.updates.applyAll', "Update All Components"),
+			category: CATEGORY,
+			f1: true
+		});
+	}
+	async run(accessor: ServicesAccessor): Promise<void> {
+		const updateService = accessor.get(IWso2ComponentUpdateService);
+		const state = await updateService.getState();
+		if (state.type !== Wso2UpdateStateType.UpdatesAvailable) {
+			return;
+		}
+		// Component updates are downloaded + applied in place; a core-app ("integrator")
+		// update is applied via the platform installer flow (§D8).
+		if (state.updates.length) {
+			await updateService.downloadUpdates();
+		} else if (state.appUpdate) {
+			await applyAppUpdate(updateService, accessor.get(IDialogService), accessor.get(INotificationService), state.appUpdate.version);
+		}
+	}
+}
+
+interface IComponentPickItem extends IQuickPickItem {
+	readonly componentId: string;
+	readonly kind: string;
+	readonly updatable: boolean;
+	readonly pending: boolean;
+	readonly overridden: boolean;
+}
+
+class ShowComponentsAction extends Action2 {
+	constructor() {
+		super({
+			id: 'wso2.updates.showComponents',
+			title: localize2('wso2.updates.showComponents', "Show Components"),
+			category: CATEGORY,
+			f1: true
+		});
+	}
+	async run(accessor: ServicesAccessor): Promise<void> {
+		const updateService = accessor.get(IWso2ComponentUpdateService);
+		const quickInputService = accessor.get(IQuickInputService);
+		const notificationService = accessor.get(INotificationService);
+		const nativeHostService = accessor.get(INativeHostService);
+		const hostService = accessor.get(IHostService);
+		const dialogService = accessor.get(IDialogService);
+		const extensionManagementService = accessor.get(IWorkbenchExtensionManagementService);
+		const statuses = await updateService.getComponentStatuses();
+		const items: IComponentPickItem[] = statuses.map(s => {
+			const updatable = !!s.availableVersion;
+			const pending = !!s.pendingVersion;
+			const overridden = !!s.overridden;
+			const detailParts = [
+				localize('wso2.updates.bundled', "bundled {0}", s.bundledVersion ?? '—'),
+				s.activeVersion && s.activeVersion !== s.bundledVersion ? localize('wso2.updates.active', "active {0}", s.activeVersion) : undefined,
+				s.availableVersion ? localize('wso2.updates.availableItem', "available {0}", s.availableVersion) : undefined,
+				s.pendingVersion ? localize('wso2.updates.pending', "pending restart {0}", s.pendingVersion) : undefined,
+				(overridden && !updatable && !pending) ? localize('wso2.updates.revertHint', "select to revert to bundled") : undefined
+			].filter(Boolean);
+			const icon = updatable ? '$(cloud-download) ' : (pending ? '$(sync) ' : (overridden ? '$(discard) ' : ''));
+			return {
+				label: `${icon}${s.id}`,
+				description: `(${s.kind})`,
+				detail: detailParts.join('  ·  '),
+				componentId: s.id,
+				kind: s.kind,
+				updatable,
+				pending,
+				overridden
+			};
+		});
+		const anyActionable = items.some(i => i.updatable || i.pending || i.overridden);
+		const picked = await quickInputService.pick(items, {
+			placeHolder: anyActionable
+				? localize('wso2.updates.componentsPlaceholderUpdatable', "Select a component to update, restart, or revert; Esc to close")
+				: localize('wso2.updates.componentsPlaceholder', "Installed WSO2 Integrator components")
+		});
+		if (!picked) {
+			return;
+		}
+		if (picked.updatable) {
+			await updateService.downloadUpdates([picked.componentId]);
+		} else if (picked.pending) {
+			notificationService.prompt(Severity.Info, localize('wso2.updates.componentPending', "{0} is downloaded. Restart WSO2 Integrator to finish updating.", picked.componentId), [
+				{ label: localize('wso2.updates.restartNow', "Restart"), run: () => nativeHostService.relaunch() }
+			]);
+		} else if (picked.overridden) {
+			await this.revert(picked, { updateService, notificationService, nativeHostService, hostService, dialogService, extensionManagementService });
+		} else {
+			notificationService.info(localize('wso2.updates.componentUpToDate', "{0} is already up to date.", picked.componentId));
+		}
+	}
+
+	private async revert(
+		picked: IComponentPickItem,
+		services: {
+			updateService: IWso2ComponentUpdateService;
+			notificationService: INotificationService;
+			nativeHostService: INativeHostService;
+			hostService: IHostService;
+			dialogService: IDialogService;
+			extensionManagementService: IWorkbenchExtensionManagementService;
+		}
+	): Promise<void> {
+		const { confirmed } = await services.dialogService.confirm({
+			message: localize('wso2.updates.revertConfirm', "Revert {0} to the bundled version?", picked.componentId),
+			primaryButton: localize('wso2.updates.revert', "Revert")
+		});
+		if (!confirmed) {
+			return;
+		}
+
+		if (picked.kind === 'extension') {
+			// Uninstalling the user-installed shadow copy lets the bundled built-in win again.
+			const installed = await services.extensionManagementService.getInstalled(ExtensionType.User);
+			const shadow = installed.find(e => e.identifier.id.toLowerCase() === picked.componentId.toLowerCase());
+			if (shadow) {
+				await services.extensionManagementService.uninstall(shadow);
+			}
+			await services.updateService.clearComponentOverride(picked.componentId);
+			services.notificationService.prompt(Severity.Info, localize('wso2.updates.revertReload', "Reload the window to finish reverting {0}.", picked.componentId), [
+				{ label: localize('wso2.updates.reloadNow', "Reload Window"), run: () => services.hostService.reload() }
+			]);
+		} else {
+			const reverted = await services.updateService.revertRuntimeOverride(picked.componentId);
+			if (reverted) {
+				services.notificationService.prompt(Severity.Info, localize('wso2.updates.revertRestart', "Restart WSO2 Integrator to finish reverting {0}.", picked.componentId), [
+					{ label: localize('wso2.updates.restartNow', "Restart"), run: () => services.nativeHostService.relaunch() }
+				]);
+			}
+		}
+	}
+}
+
+class UpdateIndicatorAction extends Action2 {
