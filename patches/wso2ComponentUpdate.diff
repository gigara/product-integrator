+		}
+
+		this.setState({ type: Wso2UpdateStateType.CheckingForUpdates, explicit });
+		try {
+			const manifest = await this.fetchManifest();
+			if (!manifest) {
+				this.setState({ type: Wso2UpdateStateType.Idle });
+				return;
+			}
+			this.lastManifest = manifest;
+			this.persistCheckMetadata(manifest);
+
+			const updates = this.resolveOfferedUpdates(manifest);
+			const appUpdate = this.resolveAppUpdate(manifest);
+
+			if (updates.length === 0 && !appUpdate) {
+				this.setState({ type: Wso2UpdateStateType.Idle });
+			} else {
+				this.setState({ type: Wso2UpdateStateType.UpdatesAvailable, updates, appUpdate });
+			}
+		} catch (err) {
+			this.logService.warn('[wso2Update] check failed', err);
+			// Background checks fail quietly; explicit checks surface an error state.
+			this.setState(explicit ? { type: Wso2UpdateStateType.Error, message: String(err) } : { type: Wso2UpdateStateType.Idle });
+		}
+	}
+
+	private async fetchManifest(): Promise<IWso2UpdateManifest | undefined> {
+		const url = `${this.updateBaseUrl}/api/v1/updates/${this.channel}/${this.platformKey()}/${this.archKey()}/manifest.json`;
+		if (!this.isAllowedUrl(url)) {
+			throw new Error(`Manifest host not allowed: ${url}`);
+		}
+		const appVersion = this.appVersion();
+		const context = await this.requestService.request({ url: `${url}?appVersion=${encodeURIComponent(appVersion)}`, callSite: 'wso2Update.checkForUpdates' }, CancellationToken.None);
+		if (context.res.statusCode === 204) {
+			return undefined;
+		}
+		if (context.res.statusCode !== 200) {
+			throw new Error(`Unexpected status ${context.res.statusCode} fetching manifest`);
+		}
+		// Read the raw bytes so the cosign signature can be verified over exactly what was served.
+		const raw = await streamToBuffer(context.stream);
+		await this.verifyManifestSignature(url, raw);
+		const manifest = JSON.parse(raw.toString()) as IWso2UpdateManifest;
+		this.validateManifest(manifest);
+		return manifest;
+	}
+
+	/**
+	 * Verifies the manifest's detached cosign signature against the embedded public key.
+	 * When no public key is configured (`product.wso2UpdatePublicKey`), verification is
+	 * skipped with a warning — integrity then rests on TLS + the host allowlist + per-artifact
+	 * sha256. When a key IS configured, a missing or invalid signature is fatal.
+	 */
+	private async verifyManifestSignature(manifestUrl: string, raw: VSBuffer): Promise<void> {
+		const publicKey = decodePublicKey(this.productService.wso2UpdatePublicKey);
+		if (!publicKey) {
+			this.logService.warn('[wso2Update] manifest signature verification disabled (no wso2UpdatePublicKey configured)');
+			return;
+		}
+		const signatureUrl = `${manifestUrl}.sig`;
+		if (!this.isAllowedUrl(signatureUrl)) {
+			throw new Error(`Signature host not allowed: ${signatureUrl}`);
+		}
+		const signatureContext = await this.requestService.request({ url: signatureUrl, callSite: 'wso2Update.manifestSignature' }, CancellationToken.None);
+		if (signatureContext.res.statusCode !== 200) {
+			throw new Error(`Missing manifest signature (HTTP ${signatureContext.res.statusCode})`);
+		}
+		const signatureBase64 = (await asText(signatureContext)) ?? '';
+		if (!verifyDetachedSignature(Buffer.from(raw.buffer), signatureBase64, publicKey)) {
+			throw new Error('Manifest signature verification failed');
+		}
+		this.logService.trace('[wso2Update] manifest signature verified');
+	}
+
+	private validateManifest(manifest: IWso2UpdateManifest): void {
+		if (manifest.platform !== this.platformKey() || manifest.arch !== this.archKey()) {
+			throw new Error('Manifest platform/arch mismatch');
+		}
+		if (manifest.expiresAt && Date.parse(manifest.expiresAt) < Date.now()) {
+			throw new Error('Manifest has expired');
+		}
+		const lastSequence = readLocalManifest(this.componentsHome)?.lastManifestSequence;
+		if (typeof lastSequence === 'number' && typeof manifest.sequence === 'number' && manifest.sequence < lastSequence) {
+			throw new Error(`Manifest sequence ${manifest.sequence} is older than last accepted ${lastSequence}`);
+		}
+	}
+
+	//#endregion
+
+	//#region resolution
+
+	private resolveOfferedUpdates(manifest: IWso2UpdateManifest): IWso2AvailableUpdate[] {
+		const local = readLocalManifest(this.componentsHome);
+		const byId = new Map(manifest.components.map(c => [c.id, c]));
+
+		// Start from the recommended set when present, else consider every component.
+		const candidateIds = manifest.recommendedSet
+			? Object.keys(manifest.recommendedSet.members)
+			: manifest.components.map(c => c.id);
+
+		// Versions that would be present if the whole candidate set were applied — used
+		// for `requires` closure so a set that upgrades a dependency together is allowed.
+		const projected = new Map<string, string>();
+		for (const id of candidateIds) {
+			const c = byId.get(id);
+			if (c) {
+				projected.set(id, c.version);
+			}
+		}
+
+		const offered: IWso2AvailableUpdate[] = [];
+		for (const id of candidateIds) {
+			const component = byId.get(id);
+			if (!component) {
+				continue;
+			}
+			const activeVersion = this.activeVersion(id, local);
+			if (activeVersion && compareVersions(component.version, activeVersion) <= 0) {
+				continue; // already current or newer
+			}
+			// Already downloaded and staged for the next restart — don't re-offer/re-download.
+			const pendingVersion = local?.components[id]?.pending?.version;
+			if (pendingVersion && compareVersions(pendingVersion, component.version) >= 0) {
+				continue;
+			}
+			if (!this.passesRollout(component)) {
+				continue;
+			}
+			if (!this.requiresSatisfied(component, manifest, local, projected)) {
+				this.logService.trace(`[wso2Update] skipping ${id}@${component.version}: unmet requirements`);
+				continue;
+			}
+			offered.push({
+				id,
+				kind: component.kind,
+				fromVersion: activeVersion,
+				toVersion: component.version,
+				releaseNotesUrl: component.releaseNotesUrl
+			});
+		}
+		return offered;
+	}
+
+	private requiresSatisfied(
+		component: IWso2ManifestComponent,
+		manifest: IWso2UpdateManifest,
+		local: ILocalComponentsManifest | undefined,
+		projected: Map<string, string>
+	): boolean {
+		if (!component.requires) {
+			return true;
+		}
+		for (const [depId, range] of Object.entries(component.requires)) {
+			const depVersion = depId === 'app'
+				? this.appVersion()
+				: (projected.get(depId) ?? this.activeVersion(depId, local) ?? this.bundledVersion(depId));
+			if (!depVersion) {
+				return false;
+			}
+			const coerced = semver.valid(depVersion) ? depVersion : semver.coerce(depVersion)?.version;
+			if (!coerced) {
+				// Can't parse — do not block on a parsing quirk; log and accept.
+				this.logService.trace(`[wso2Update] cannot parse version '${depVersion}' for requirement ${depId} ${range}; accepting`);
+				continue;
+			}
+			try {
+				if (!semver.satisfies(coerced, range)) {
+					return false;
+				}
+			} catch {
+				this.logService.trace(`[wso2Update] invalid range '${range}' for ${depId}; accepting`);
+			}
+		}
+		return true;
+	}
+
+	private resolveAppUpdate(manifest: IWso2UpdateManifest): IWso2AvailableAppUpdate | undefined {
+		// On macOS, when the stock update feed is configured the native Squirrel.Mac updater
+		// (darwinUpdateService) owns core-app updates — don't also offer them here.
+		if (process.platform === 'darwin' && this.productService.updateUrl) {
+			return undefined;
+		}
+		const app = manifest.app;
+		if (!app) {
+			return undefined;
+		}
+		if (compareVersions(app.version, this.appVersion()) <= 0) {
+			return undefined;
+		}
+		if (app.rollout && !this.passesRolloutValue('app', app.version, app.rollout.percentage)) {
+			return undefined;
+		}
+		return { version: app.version, installerUrl: app.installer.url, releaseNotesUrl: app.releaseNotesUrl };
+	}
+
+	//#endregion
+
+	//#region download & apply
+
+	async downloadUpdates(componentIds?: readonly string[]): Promise<void> {
+		const manifest = this.lastManifest;
+		if (!manifest) {
+			return;
+		}
+
+		// Resolve which components to download. Explicit ids act directly on the
+		// manifest so a single component can be updated even when it isn't part of
+		// the offered/recommended set; otherwise fall back to the offered set.
+		let targetComponents: IWso2ManifestComponent[];
+		if (componentIds && componentIds.length) {
+			const wanted = new Set(componentIds);
+			targetComponents = manifest.components.filter(c => wanted.has(c.id));
+		} else if (this._state.type === Wso2UpdateStateType.UpdatesAvailable) {
+			const offered = new Set(this._state.updates.map(u => u.id));
+			targetComponents = manifest.components.filter(c => offered.has(c.id));
+		} else {
+			targetComponents = [];
+		}
+
+		if (!targetComponents.length) {
+			return;
+		}
+
+		this.setState({ type: Wso2UpdateStateType.Downloading });
+		const stagedExtensions: IWso2StagedExtension[] = [];
+		let restartRequired = false;
+
+		try {
+			const localBefore = readLocalManifest(this.componentsHome);
+			for (const component of targetComponents) {
+				if (component.kind === 'extension') {
+					const vsixPath = await this.downloadExtension(component);
+					stagedExtensions.push({ id: component.id, version: component.version, vsixPath });
+				} else {
+					// Already staged at (or above) this version — don't re-download; it just
+					// needs a restart to activate.
+					const pending = localBefore?.components[component.id]?.pending?.version;
+					if (pending && compareVersions(pending, component.version) >= 0) {
+						this.logService.info(`[wso2Update] ${component.id}@${component.version} already staged; skipping re-download`);
+						restartRequired = true;
+						continue;
+					}
+					await this.stageRuntime(component);
+					restartRequired = true;
+				}
+			}
+			this.setState({ type: Wso2UpdateStateType.Downloaded, stagedExtensions, restartRequired });
+		} catch (err) {
+			this.logService.error('[wso2Update] download/apply failed', err);
+			this.setState({ type: Wso2UpdateStateType.Error, message: String(err) });
+		}
+	}
+
+	private async downloadExtension(component: IWso2ManifestComponent): Promise<string> {
+		const dir = path.join(this.stagingHome, component.id, component.version);
+		await fs.promises.mkdir(dir, { recursive: true });
+		const vsixPath = path.join(dir, `${component.id}-${component.version}.vsix`);
+		await this.downloadAndVerify(component.artifact.url, vsixPath, component.artifact.sha256);
+		return vsixPath;
+	}
+
+	private async stageRuntime(component: IWso2ManifestComponent): Promise<void> {
+		this.logService.info(`[wso2Update] staging runtime ${component.id}@${component.version} from ${component.artifact.url}`);
+		const stagingDir = path.join(this.stagingHome, component.id, component.version);
+		await fs.promises.rm(stagingDir, { recursive: true, force: true });
+		await fs.promises.mkdir(stagingDir, { recursive: true });
+
+		const archivePath = path.join(stagingDir, `${component.id}-${component.version}.zip`);
+		await this.downloadAndVerify(component.artifact.url, archivePath, component.artifact.sha256);
+		this.logService.info(`[wso2Update] verified ${component.id}@${component.version}; extracting`);
+
+		const extractDir = path.join(stagingDir, 'extracted');
+		await extract(archivePath, extractDir, {}, CancellationToken.None);
+		await fs.promises.rm(archivePath, { force: true });
+
+		// The JRE component is a WRAPPER directory containing a single `jdk-*` home (that is how
+		// it ships bundled and how it is seeded), so keep the extracted tree as-is — do not
+		// descend into the jdk dir. `${COMPONENT:jre}` / WSO2_INTEGRATOR_JRE_DIR then resolve to a
+		// dir the `bal`/`icp` launchers glob as `<dir>/jdk-*`. Other runtimes descend as usual.
+		const runtimeRoot = component.id === 'jre' ? extractDir : this.resolveExtractedRoot(extractDir);
+
+		// Promote atomically into the versioned components directory.
+		const targetDir = path.join(this.componentsHome, component.id, component.version);
+		await fs.promises.rm(targetDir, { recursive: true, force: true });
+		await fs.promises.mkdir(path.dirname(targetDir), { recursive: true });
+		await fs.promises.rename(runtimeRoot, targetDir);
+		// Normalize executable bits — zip archives sometimes drop them, leaving launchers
+		// like bin/bal or the bundled JRE unrunnable ("permission denied").
+		ensureExecutablePermissions(targetDir);
+		await fs.promises.rm(stagingDir, { recursive: true, force: true });
+		this.logService.info(`[wso2Update] staged runtime ${component.id}@${component.version} at ${targetDir} (pending restart)`);
+
+		// Record as pending; activation happens at the next startup (bootstrap).
+		const relPath = path.join('components', component.id, component.version);
+		this.updateLocalManifest(manifest => {
+			const entry = manifest.components[component.id] ?? (manifest.components[component.id] = {});
+			entry.bundledVersion = entry.bundledVersion ?? this.bundledVersion(component.id);
+			entry.pending = { version: component.version, path: relPath, installedAt: new Date().toISOString(), healthy: false };
+		});
+
+		// Verify the pending state actually persisted; a silent write failure here would
+		// otherwise show a "restart" prompt while nothing is staged, causing a re-offer loop.
+		const persisted = readLocalManifest(this.componentsHome)?.components[component.id]?.pending?.version;
+		if (persisted !== component.version) {
+			throw new Error(`Failed to persist pending state for ${component.id}@${component.version} at ${getComponentsManifestPath(this.componentsHome)}`);
+		}
+		this.logService.info(`[wso2Update] recorded pending ${component.id}@${component.version} in ${getComponentsManifestPath(this.componentsHome)}`);
+	}
+
+	/** Descends into a single top-level subdirectory when the archive nests the runtime root. */
+	private resolveExtractedRoot(extractDir: string): string {
+		try {
+			const entries = fs.readdirSync(extractDir, { withFileTypes: true });
+			const dirs = entries.filter(e => e.isDirectory());
+			const hasBin = entries.some(e => e.name === 'bin');
+			if (!hasBin && dirs.length === 1 && entries.length === 1) {
+				return path.join(extractDir, dirs[0].name);
+			}
+		} catch {
+			// fall through
+		}
+		return extractDir;
+	}
+
+	private async downloadAndVerify(url: string, destPath: string, expectedSha256: string): Promise<void> {
+		if (!this.isAllowedUrl(url)) {
+			throw new Error(`Artifact host not allowed: ${url}`);
+		}
+		this.logService.info(`[wso2Update] downloading ${url}`);
+		const context = await this.requestService.request({ url, callSite: 'wso2Update.download' }, CancellationToken.None);
+		if (context.res.statusCode !== 200) {
+			throw new Error(`Unexpected status ${context.res.statusCode} downloading ${url}`);
+		}
+		const hash = createHash('sha256');
+		const out = fs.createWriteStream(destPath);
+		await new Promise<void>((resolve, reject) => {
+			// A write can fail asynchronously (disk full, I/O error); surface it so the download
+			// rejects instead of hanging or resolving with a truncated file.
+			out.on('error', err => reject(err));
+			listenStream(context.stream, {
+				onData: chunk => {
+					hash.update(chunk.buffer);
+					out.write(chunk.buffer);
+				},
+				onError: err => {
+					out.destroy();
+					reject(err);
+				},
+				onEnd: () => {
+					out.end(() => resolve());
+				}
+			});
+		});
+		const actual = hash.digest('hex').toLowerCase();
+		if (actual !== expectedSha256.toLowerCase()) {
+			await fs.promises.rm(destPath, { force: true });
+			throw new Error(`Checksum mismatch for ${url} (expected ${expectedSha256}, got ${actual})`);
+		}
+	}
+
+	//#endregion
+
+	//#region status & bookkeeping
+
+	async getComponentStatuses(): Promise<IWso2ComponentStatus[]> {
+		const local = readLocalManifest(this.componentsHome);
+		const bundled = this.productService.bundledComponents ?? {};
+		const statuses = new Map<string, IWso2ComponentStatus>();
+
+		// Runtime components known from the bundled set.
+		for (const [id, version] of Object.entries(bundled)) {
+			statuses.set(id, { id, kind: 'runtime', bundledVersion: version, activeVersion: this.activeVersion(id, local) ?? version, pendingVersion: local?.components[id]?.pending?.version, overridden: !!local?.components[id]?.active });
+		}
+		// Anything recorded locally that isn't in the bundled set (e.g. extensions).
+		if (local) {
+			for (const [id, entry] of Object.entries(local.components)) {
+				if (!statuses.has(id)) {
+					statuses.set(id, { id, kind: entry.active?.via === 'user-extension' ? 'extension' : 'runtime', bundledVersion: entry.bundledVersion, activeVersion: entry.active?.version ?? entry.bundledVersion, pendingVersion: entry.pending?.version, overridden: !!entry.active });
+				}
+			}
+		}
+		// Overlay available versions from the last manifest.
+		if (this.lastManifest) {
+			for (const component of this.lastManifest.components) {
+				const existing = statuses.get(component.id);
+				const activeVersion = this.activeVersion(component.id, local);
+				const pendingVersion = local?.components[component.id]?.pending?.version;
+				// Not "available" if already current, or already staged (pending) at that version.
+				const availableVersion = ((!activeVersion || compareVersions(component.version, activeVersion) > 0)
+					&& !(pendingVersion && compareVersions(pendingVersion, component.version) >= 0))
+					? component.version : undefined;
+				statuses.set(component.id, {
+					id: component.id,
+					kind: component.kind,
+					bundledVersion: existing?.bundledVersion ?? this.bundledVersion(component.id),
+					activeVersion: existing?.activeVersion ?? activeVersion,
+					availableVersion,
+					pendingVersion: existing?.pendingVersion ?? local?.components[component.id]?.pending?.version,
+					overridden: existing?.overridden ?? !!local?.components[component.id]?.active
+				});
+			}
+		}
+		return [...statuses.values()];
+	}
+
+	async recordExtensionInstalled(id: string, version: string): Promise<void> {
+		this.updateLocalManifest(manifest => {
+			const entry = manifest.components[id] ?? (manifest.components[id] = {});
+			entry.bundledVersion = entry.bundledVersion ?? this.bundledVersion(id);
+			entry.active = { version, via: 'user-extension', installedAt: new Date().toISOString(), healthy: true };
+		});
+	}
+
+	async revertRuntimeOverride(id: string): Promise<boolean> {
+		let reverted = false;
+		const dataFolderHome = path.dirname(this.componentsHome);
+		this.updateLocalManifest(manifest => {
+			const entry = manifest.components[id];
+			if (!entry || !entry.active || entry.active.via === 'user-extension') {
+				return; // nothing to revert, or an extension shadow (handled by the renderer)
+			}
+			const current = entry.active;
+			const previous = entry.previous;
+			entry.pending = null;
+			if (previous && previous.path && fs.existsSync(path.join(dataFolderHome, previous.path))) {
+				entry.active = { ...previous, healthy: false };
+			} else {
+				entry.active = null; // no retained previous → fall back to the bundled version
+			}
+			entry.previous = current;
+			reverted = true;
+		});
+		if (reverted) {
+			this.logService.info(`[wso2Update] reverted runtime override ${id} (restart required)`);
+		}
+		return reverted;
+	}
+
+	async clearComponentOverride(id: string): Promise<void> {
+		this.updateLocalManifest(manifest => {
+			const entry = manifest.components[id];
+			if (entry && entry.active) {
+				entry.previous = entry.active;
+				entry.active = null;
+			}
+		});
+	}
+
+	/**
+	 * We only reach service construction when the app booted successfully, so any override that
+	 * was just activated (marked `healthy: false` by the bootstrap) is now known good — flag it
+	 * healthy and garbage-collect stale versioned directories (keeping active + previous for revert).
+	 */
+	private markHealthyAndGarbageCollect(): void {
+		const manifest = readLocalManifest(this.componentsHome);
+		if (!manifest) {
+			return;
+		}
+		let changed = false;
+		for (const [id, entry] of Object.entries(manifest.components)) {
+			const active = entry.active;
+			if (active && active.path && active.healthy === false) {
+				// App booted successfully with this override → confirm healthy and clear the
+				// auto-fallback boot counter (§D5).
+				entry.active = { ...active, healthy: true, bootCount: undefined };
+				changed = true;
+				this.logService.trace(`[wso2Update] marked ${id}@${active.version} healthy`);
+			}
+			this.garbageCollectComponentVersions(id, entry);
+		}
+		if (changed) {
+			writeLocalManifest(this.componentsHome, manifest);
+		}
+	}
+
+	/** Removes versioned component directories other than the active and previous versions. */
+	private garbageCollectComponentVersions(id: string, entry: ILocalComponentEntry): void {
+		const componentDir = path.join(this.componentsHome, id);
+		let versions: string[];
+		try {
+			versions = fs.readdirSync(componentDir, { withFileTypes: true }).filter(e => e.isDirectory()).map(e => e.name);
+		} catch {
+			return; // no versioned directories (e.g. an extension shadow, installed elsewhere)
+		}
+		// Keep active + previous (for revert) and the bundled-version directory (the first-run
+		// seed baseline, §D8): its `${COMPONENT:*}` fallback target must never be collected, or a
+		// revert-to-bundled after an update would strand the runtime. Key on the product's bundled
+		// version too (not just the recorded entry, which may be unset).
+		const keep = new Set([entry.active?.version, entry.previous?.version, entry.bundledVersion, this.bundledVersion(id)].filter((v): v is string => !!v));
+		for (const version of versions) {
+			if (keep.has(version)) {
+				continue;
+			}
+			try {
+				fs.rmSync(path.join(componentDir, version), { recursive: true, force: true });
+				this.logService.info(`[wso2Update] GC removed ${id}@${version}`);
+			} catch (err) {
+				this.logService.warn(`[wso2Update] GC failed for ${id}@${version}`, err);
+			}
+		}
+	}
+
+	async downloadAppInstaller(): Promise<void> {
+		const appUpdate = this._state.type === Wso2UpdateStateType.UpdatesAvailable ? this._state.appUpdate : undefined;
+		const url = appUpdate?.installerUrl ?? (this.lastManifest?.app?.installer.url);
+		if (!url) {
+			return;
+		}
+		if (!this.isAllowedUrl(url)) {
+			this.logService.warn(`[wso2Update] refusing to open non-allowlisted installer URL: ${url}`);
+			return;
+		}
+		await shell.openExternal(url);
+	}
+
+	async applyAppUpdate(): Promise<void> {
+		// Only Windows supports a silent in-place upgrade here; macOS uses Squirrel.Mac and
+		// Linux uses the notify+download flow. Fall back for those platforms.
+		if (process.platform !== 'win32') {
+			return this.downloadAppInstaller();
+		}
+		const app = this.lastManifest?.app;
+		if (!app) {
+			return;
+		}
+		const { url, sha256 } = app.installer;
+		if (!this.isAllowedUrl(url)) {
+			this.logService.warn(`[wso2Update] refusing non-allowlisted app installer URL: ${url}`);
+			throw new Error(`App installer host not allowed: ${url}`);
+		}
+		// Defense in depth: the version comes from the (signature-verified) manifest, but it is
+		// interpolated into a file path and a cmd.exe command line below — reject anything that
+		// isn't a plain version string so shell metacharacters can never reach the command.
+		if (!/^[0-9A-Za-z.+_-]+$/.test(app.version)) {
+			throw new Error(`Refusing to apply app update with unexpected version string: ${app.version}`);
+		}
+
+		// Download and verify the editor-only update MSI (sha256 from the signed manifest is the
+		// integrity chain, matching the component download path) before executing anything.
+		const downloadsHome = getDownloadsHome(os.homedir(), this.dataFolderName);
+		await fs.promises.mkdir(downloadsHome, { recursive: true });
+		const msiPath = path.join(downloadsHome, `wso2-integrator-${app.version}-update.msi`);
+		this.logService.info(`[wso2Update] downloading app update ${app.version} MSI`);
+		await this.downloadAndVerify(url, msiPath, sha256);
+		this.logService.info(`[wso2Update] verified app update MSI at ${msiPath}; scheduling silent install on quit`);
+
+		// Run the per-user MSI silently (no UAC), then relaunch. The app must quit first so
+		// `WSO2 Integrator.exe` is not file-locked; the short delay gives the process time to
+		// exit before msiexec touches the install directory.
+		const exe = process.execPath;
+		const cmd = `ping -n 3 127.0.0.1 >nul & msiexec /i "${msiPath}" /qn /norestart & start "" "${exe}"`;
+		const child = spawn(process.env['comspec'] || 'cmd.exe', ['/s', '/c', `"${cmd}"`], {
+			detached: true,
+			stdio: 'ignore',
+			windowsVerbatimArguments: true
+		});
+		child.unref();
+
+		this.lifecycleMainService.quit();
+	}
+
+	private persistCheckMetadata(manifest: IWso2UpdateManifest): void {
+		this.updateLocalManifest(local => {
+			local.channel = this.channel;
+			local.lastCheck = new Date().toISOString();
+			if (typeof manifest.sequence === 'number') {
+				local.lastManifestSequence = manifest.sequence;
+			}
+		});
+	}
+
+	private updateLocalManifest(mutate: (manifest: ILocalComponentsManifest) => void): void {
+		try {
+			const manifest = readLocalManifest(this.componentsHome) ?? {
+				schemaVersion: LOCAL_MANIFEST_SCHEMA_VERSION,
+				bundledAppVersion: this.appVersion(),
+				components: {}
+			};
+			manifest.bundledAppVersion = this.appVersion();
+			mutate(manifest);
+			writeLocalManifest(this.componentsHome, manifest);
+		} catch (err) {
+			this.logService.warn('[wso2Update] failed to persist local manifest', err);
+		}
+	}
+
+	//#endregion
+
+	//#region helpers
+
+	private activeVersion(id: string, local: ILocalComponentsManifest | undefined): string | undefined {
+		return local?.components[id]?.active?.version ?? this.bundledVersion(id);
+	}
+
+	private bundledVersion(id: string): string | undefined {
+		// Runtime components (ballerina-runtime / jre / icp) come from bundledComponents;
+		// extension components' bundled versions live in builtInExtensions.
+		const runtime = this.productService.bundledComponents?.[id];
+		if (runtime) {
+			return runtime;
+		}
+		return this.productService.builtInExtensions?.find(e => e.name === id)?.version;
+	}
+
+	private appVersion(): string {
+		return (this.productService as { wiversion?: string }).wiversion ?? this.productService.version;
+	}
+
+	private passesRollout(component: IWso2ManifestComponent): boolean {
+		if (!component.rollout || component.rollout.percentage >= 100) {
+			return true;
+		}
+		return this.passesRolloutValue(component.id, component.version, component.rollout.percentage);
+	}
+
+	private passesRolloutValue(id: string, version: string, percentage: number): boolean {
+		if (percentage >= 100) {
+			return true;
+		}
+		if (percentage <= 0) {
+			return false;
+		}
+		const bucket = parseInt(createHash('sha1').update(`${this.deviceId()}:${id}:${version}`).digest('hex').slice(0, 8), 16) % 100;
+		return bucket < percentage;
+	}
+
+	private _deviceId: string | undefined;
+	private deviceId(): string {
+		if (this._deviceId) {
+			return this._deviceId;
+		}
+		const existing = readLocalManifest(this.componentsHome)?.deviceId;
+		if (existing) {
+			this._deviceId = existing;
+			return existing;
+		}
+		// Generate a stable, never-transmitted id used only for local rollout bucketing.
+		const id = createHash('sha1').update(`${os.hostname()}:${os.homedir()}:${Date.now()}`).digest('hex');
+		this._deviceId = id;
+		this.updateLocalManifest(manifest => { manifest.deviceId = id; });
+		return id;
+	}
+
+	private platformKey(): string {
+		return process.platform; // 'darwin' | 'linux' | 'win32'
+	}
+
+	private archKey(): string {
+		return process.arch === 'arm64' ? 'arm64' : 'x64';
+	}
+
+	private isAllowedUrl(url: string): boolean {
+		try {
+			const parsed = new URL(url);
+			const host = parsed.hostname.toLowerCase();
+			const isLoopback = host === 'localhost' || host === '127.0.0.1' || host === '::1' || host === '[::1]';
+			// Require HTTPS except for loopback hosts, which are used for local
+			// update-server development and cannot be intercepted remotely.
+			if (parsed.protocol !== 'https:' && !(isLoopback && parsed.protocol === 'http:')) {
+				return false;
+			}
+			if (isLoopback) {
+				return true;
+			}
+			const configuredHost = this.updateBaseUrl ? new URL(this.updateBaseUrl).hostname.toLowerCase() : undefined;
+			if (configuredHost && host === configuredHost) {
+				return true;
+			}
+			return ALLOWED_HOST_SUFFIXES.some(suffix => host === suffix || host.endsWith(`.${suffix}`));
+		} catch {
+			return false;
+		}
+	}
+
+	//#endregion
+}
