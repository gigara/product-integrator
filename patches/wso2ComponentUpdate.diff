+
+import * as fs from 'fs';
+import * as path from 'path';
+
+/**
+ * Local components manifest bookkeeping. This module intentionally depends only on
+ * `node:fs` / `node:path` (no DI, no Electron) so it can be used both by the
+ * main-process update service and by the early `main.ts` bootstrap, which activates
+ * pending runtime updates before any window or extension host is created.
+ */
+
+export interface ILocalComponentVersion {
+	readonly version: string;
+	/** Path to the component root, relative to the data-folder home or absolute. */
+	readonly path?: string;
+	/** For extensions installed as user shadow copies. */
+	readonly via?: 'user-extension';
+	readonly installedAt?: string;
+	readonly healthy?: boolean;
+	/** Consecutive boots this override has been active without being confirmed healthy (auto-fallback). */
+	readonly bootCount?: number;
+}
+
+export interface ILocalComponentEntry {
+	bundledVersion?: string;
+	active?: ILocalComponentVersion | null;
+	previous?: ILocalComponentVersion | null;
+	pending?: ILocalComponentVersion | null;
+}
+
+export interface ILocalComponentsManifest {
+	schemaVersion: number;
+	bundledAppVersion?: string;
+	channel?: string;
+	lastCheck?: string;
+	lastManifestSequence?: number;
+	/** Locally generated, never transmitted; used only for rollout bucketing. */
+	deviceId?: string;
+	components: { [id: string]: ILocalComponentEntry };
+}
+
+export const LOCAL_MANIFEST_SCHEMA_VERSION = 1;
+
+export function getComponentsHome(homeDir: string, dataFolderName: string): string {
+	return path.join(homeDir, dataFolderName, 'components');
+}
+
+export function getComponentsManifestPath(componentsHome: string): string {
+	return path.join(componentsHome, 'manifest.json');
+}
+
+export function getStagingHome(homeDir: string, dataFolderName: string): string {
+	return path.join(homeDir, dataFolderName, 'updates', 'staging');
+}
+
+export function getDownloadsHome(homeDir: string, dataFolderName: string): string {
+	return path.join(homeDir, dataFolderName, 'updates', 'downloads');
+}
+
+/** Reads the local manifest, returning `undefined` if it is missing or unreadable. */
+export function readLocalManifest(componentsHome: string): ILocalComponentsManifest | undefined {
+	try {
+		const manifestPath = getComponentsManifestPath(componentsHome);
+		if (!fs.existsSync(manifestPath)) {
+			return undefined;
+		}
+		const parsed = JSON.parse(fs.readFileSync(manifestPath, 'utf8'));
+		if (!parsed || typeof parsed !== 'object' || typeof parsed.components !== 'object') {
+			return undefined;
+		}
+		return parsed as ILocalComponentsManifest;
+	} catch {
+		return undefined;
+	}
+}
+
+/** Atomically writes the local manifest (write temp file + rename). */
+export function writeLocalManifest(componentsHome: string, manifest: ILocalComponentsManifest): void {
+	fs.mkdirSync(componentsHome, { recursive: true });
+	const manifestPath = getComponentsManifestPath(componentsHome);
+	const tmpPath = `${manifestPath}.tmp`;
+	fs.writeFileSync(tmpPath, JSON.stringify(manifest, null, 2), 'utf8');
+	fs.renameSync(tmpPath, manifestPath);
+}
+
+/**
+ * Resolves the active override root (absolute path) for each runtime component that
+ * has one installed. Extension shadow copies (`via: 'user-extension'`) are excluded
+ * because they are resolved by the extension scanner, not via `runtimeEnv`.
+ */
+export function getActiveOverrides(manifest: ILocalComponentsManifest | undefined, dataFolderHome: string): Record<string, string> {
+	const overrides: Record<string, string> = {};
+	if (!manifest) {
+		return overrides;
+	}
+	for (const [id, entry] of Object.entries(manifest.components)) {
+		const active = entry?.active;
+		if (active && typeof active.path === 'string' && active.path.length > 0) {
+			overrides[id] = path.normalize(path.isAbsolute(active.path) ? active.path : path.join(dataFolderHome, active.path));
+		}
+	}
+	return overrides;
+}
+
+/**
+ * Activates any runtime components staged as `pending`: if the staged directory
+ * exists, the previous active version is retained (for revert) and the pending
+ * version becomes active; otherwise the invalid pending entry is discarded. This is
+ * safe to call from the bootstrap because it only rewrites the manifest — the staged
+ * directories were already put in place at download time.
+ *
+ * Returns the resolved active overrides after activation.
+ */
+export function activatePendingRuntimeComponents(dataFolderHome: string, log?: (message: string) => void): Record<string, string> {
+	// `dataFolderHome` is `<home>/<dataFolderName>`; components live under it.
+	const componentsHome = path.join(dataFolderHome, 'components');
+	const manifest = readLocalManifest(componentsHome);
+	if (!manifest) {
+		return {};
+	}
+
+	let changed = false;
+	for (const [id, entry] of Object.entries(manifest.components)) {
+		const pending = entry?.pending;
+		if (!pending) {
+			continue;
+		}
+		const targetPath = typeof pending.path === 'string' && pending.path.length > 0
+			? (path.isAbsolute(pending.path) ? pending.path : path.join(dataFolderHome, pending.path))
+			: undefined;
+		if (targetPath && fs.existsSync(targetPath)) {
+			if (entry.active && entry.active.version !== pending.version) {
+				entry.previous = entry.active;
+			}
+			entry.active = { ...pending, healthy: false };
+			entry.pending = null;
+			changed = true;
+			log?.(`Activated component ${id}@${pending.version}`);
+		} else {
+			entry.pending = null;
+			changed = true;
+			log?.(`Discarded invalid pending component ${id}@${pending.version} (missing ${targetPath ?? 'path'})`);
+		}
+	}
+
+	if (changed) {
+		try {
+			writeLocalManifest(componentsHome, manifest);
+		} catch {
+			// Non-fatal: fall back to whatever is currently on disk.
+		}
+	}
+
+	return getActiveOverrides(manifest, dataFolderHome);
+}
+
+/**
+ * Crash-loop safety net (auto-fallback, §D5): a runtime override is activated as `healthy: false`
+ * and confirmed healthy by the update service once the app boots successfully. If the app never
+ * reaches that point — e.g. a bad runtime crash-loops the main process — the override stays
+ * unhealthy across boots. This is called at bootstrap (before the runtime env is resolved) and
+ * increments a per-override boot counter; once it exceeds `maxUnhealthyBoots` the override is
+ * automatically rolled back to the previous version (or the bundled baseline when no previous
+ * dir remains), so the app can start again. Extension shadow copies are excluded (the extension
+ * host handles those). Returns the ids that were rolled back.
+ */
+export function enforceRuntimeHealthFallback(dataFolderHome: string, maxUnhealthyBoots: number, log?: (message: string) => void): string[] {
+	const componentsHome = path.join(dataFolderHome, 'components');
+	const manifest = readLocalManifest(componentsHome);
+	if (!manifest) {
+		return [];
+	}
+	const reverted: string[] = [];
+	let changed = false;
+	for (const [id, entry] of Object.entries(manifest.components)) {
+		const active = entry?.active;
+		if (!active || active.healthy !== false || active.via === 'user-extension') {
+			continue;
+		}
+		const attempts = (active.bootCount ?? 0) + 1;
+		if (attempts > maxUnhealthyBoots) {
+			const prev = entry.previous;
+			const prevPath = prev && typeof prev.path === 'string' && prev.path.length > 0
+				? (path.isAbsolute(prev.path) ? prev.path : path.join(dataFolderHome, prev.path))
+				: undefined;
+			entry.active = (prevPath && fs.existsSync(prevPath)) ? { ...prev!, healthy: true } : null;
+			reverted.push(id);
+			log?.(`Auto-reverted ${id}@${active.version} after ${attempts - 1} unhealthy boot(s)`);
+		} else {
+			entry.active = { ...active, bootCount: attempts };
+			log?.(`Component ${id}@${active.version} unhealthy boot attempt ${attempts}`);
+		}
+		changed = true;
+	}
+	if (changed) {
+		try {
+			writeLocalManifest(componentsHome, manifest);
+		} catch {
+			// Non-fatal: fall back to whatever is currently on disk.
+		}
+	}
+	return reverted;
+}
+
+/**
+ * Drops component overrides that a freshly installed full app has caught up with or
+ * superseded (bundled version >= active override version). Extension shadow copies
+ * self-heal via the extension scanner's semver dedup and are left untouched here.
+ */
+export function reconcileBundledVersions(
+	componentsHome: string,
+	bundledComponents: { readonly [id: string]: string } | undefined,
+	log?: (message: string) => void
+): void {
+	if (!bundledComponents) {
+		return;
+	}
+	const manifest = readLocalManifest(componentsHome);
+	if (!manifest) {
+		return;
+	}
+	let changed = false;
+	for (const [id, bundledVersion] of Object.entries(bundledComponents)) {
+		const entry = manifest.components[id];
+		if (!entry) {
+			continue;
+		}
+		entry.bundledVersion = bundledVersion;
+		const active = entry.active;
+		if (active && active.via !== 'user-extension' && active.version && compareVersions(bundledVersion, active.version) >= 0) {
+			entry.previous = active;
+			entry.active = null;
+			changed = true;
+			log?.(`Dropped override ${id}@${active.version} superseded by bundled ${bundledVersion}`);
+		}
+	}
+	if (changed) {
+		try {
+			writeLocalManifest(componentsHome, manifest);
+		} catch {
+			// Non-fatal.
+		}
+	}
+}
+
+/**
+ * Normalizes executable permissions in an extracted runtime tree. Zip archives may
+ * carry missing or malformed unix permission bits (e.g. an entry with no owner-execute
+ * bit), which leaves launchers like `bin/bal` or the bundled JRE's `java` unrunnable
+ * ("permission denied"). Any file inside a `bin/` directory, or any file that already
+ * has some execute bit, is set to 0755 (preserving the non-permission mode bits).
+ * Symlinks are skipped, and on Windows the execute bits are meaningless (harmless no-op).
+ */
+export function ensureExecutablePermissions(root: string): void {
+	const walk = (dir: string): void => {
+		let entries: fs.Dirent[];
+		try {
+			entries = fs.readdirSync(dir, { withFileTypes: true });
+		} catch {
+			return;
+		}
+		const inBin = path.basename(dir) === 'bin';
+		for (const entry of entries) {
+			const full = path.join(dir, entry.name);
+			if (entry.isDirectory()) {
+				walk(full);
+			} else if (entry.isFile()) {
+				try {
+					const mode = fs.statSync(full).mode;
+					if (inBin || (mode & 0o111)) {
+						fs.chmodSync(full, (mode & ~0o777) | 0o755);
+					}
+				} catch {
+					// ignore individual files we can't stat/chmod
+				}
+			}
+		}
+	};
+	walk(root);
+}
+
+/**
+ * Copies bundled runtime component directories out of the app install tree into the
+ * per-user components home on first run, so `${COMPONENT:<id>}` can resolve to a location
+ * no core-app updater will delete (see design doc §D8). This lets the core-app update
+ * ship editor-only: the seeded copy survives a `.app`/MSI/deb replacement of the install.
+ *
+ * `seeds` maps component id -> { srcDir (absolute, in the install tree), version }. A
+ * component whose seeded versioned directory already exists is skipped (idempotent), and a
+ * component whose source directory is missing is skipped. The copy goes through a staging
+ * directory promoted with `rename()`, so an interrupted copy never leaves a half-populated
+ * versioned directory that would be mistaken for a complete seed on the next run.
+ */
+export function seedBundledComponents(
+	componentsHome: string,
+	seeds: { [id: string]: { srcDir: string; version: string } },
+	log?: (message: string) => void
+): void {
+	for (const [id, seed] of Object.entries(seeds)) {
+		const { srcDir, version } = seed;
+		if (!version) {
+			continue;
+		}
+		const target = path.join(componentsHome, id, version);
+		if (fs.existsSync(target) || !fs.existsSync(srcDir)) {
+			continue;
+		}
+		const staging = `${target}.seeding`;
+		try {
+			fs.rmSync(staging, { recursive: true, force: true });
+			fs.mkdirSync(path.dirname(target), { recursive: true });
+			fs.cpSync(srcDir, staging, { recursive: true });
+			ensureExecutablePermissions(staging);
+			fs.renameSync(staging, target);
+			log?.(`Seeded ${id}@${version} from ${srcDir}`);
+		} catch (err) {
+			fs.rmSync(staging, { recursive: true, force: true });
+			log?.(`Failed to seed ${id}@${version}: ${err}`);
+		}
+	}
+}
+
+/**
+ * Compares two dotted-numeric version strings (e.g. `2201.13.4`, `5.0.0.1`).
+ * Returns 1 if a > b, -1 if a < b, 0 if equal. Non-numeric segments compare as 0.
+ */
+export function compareVersions(a: string, b: string): number {
+	const pa = a.split('.');
+	const pb = b.split('.');
+	const len = Math.max(pa.length, pb.length);
+	for (let i = 0; i < len; i++) {
+		const na = parseInt(pa[i] ?? '0', 10) || 0;
+		const nb = parseInt(pb[i] ?? '0', 10) || 0;
+		if (na > nb) {
+			return 1;
+		}
+		if (na < nb) {
+			return -1;
+		}
+	}
+	return 0;
+}
