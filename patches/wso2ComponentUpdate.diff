+
+export class Wso2ComponentUpdateService extends Disposable implements IWso2ComponentUpdateService {
+
+	declare readonly _serviceBrand: undefined;
+
+	private readonly _onStateChange = this._register(new Emitter<Wso2UpdateState>());
+	readonly onStateChange = this._onStateChange.event;
+
+	private _state: Wso2UpdateState = { type: Wso2UpdateStateType.Idle };
+	async getState(): Promise<Wso2UpdateState> { return this._state; }
