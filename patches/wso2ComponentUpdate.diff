+/*---------------------------------------------------------------------------------------------
+ *  Copyright (c) Microsoft Corporation. All rights reserved.
+ *  Licensed under the MIT License. See License.txt in the project root for license information.
+ *--------------------------------------------------------------------------------------------*/
+
+import { Event } from '../../../base/common/event.js';
+import { createDecorator } from '../../instantiation/common/instantiation.js';
+
+export const IWso2ComponentUpdateService = createDecorator<IWso2ComponentUpdateService>('wso2ComponentUpdateService');
+
+/**
+ * Component kinds delivered by the WSO2 update server. `extension` components are
+ * installed as user-extension shadow copies; `runtime` components (Ballerina
+ * runtime, custom JRE, ICP) are staged into versioned directories and activated
+ * at the next startup.
+ */
+export type Wso2ComponentKind = 'extension' | 'runtime';
+
+/** A signed, downloadable artifact referenced by a manifest entry. */
+export interface IWso2Artifact {
+	readonly url: string;
+	readonly sha256: string;
+	readonly sizeBytes?: number;
+	readonly signature?: {
+		readonly sigUrl: string;
+		readonly certUrl: string;
+	};
+}
+
+/** A single updatable component in the server manifest. */
+export interface IWso2ManifestComponent {
+	readonly id: string;
+	readonly kind: Wso2ComponentKind;
+	readonly version: string;
+	readonly artifact: IWso2Artifact;
+	/** Semver ranges keyed by component id or the literal `app`. */
+	readonly requires?: { readonly [id: string]: string };
+	readonly releaseNotesUrl?: string;
+	readonly rollout?: { readonly percentage: number };
+}
+
+/** The full-app installer entry in the server manifest. */
+export interface IWso2ManifestApp {
+	readonly version: string;
+	readonly minAutoUpdateFromVersion?: string;
+	readonly installer: IWso2Artifact;
+	readonly releaseNotesUrl?: string;
+	readonly rollout?: { readonly percentage: number };
+}
+
+/** The tested "release train" the client offers as a single bundle. */
+export interface IWso2RecommendedSet {
+	readonly name: string;
+	readonly members: { readonly [id: string]: string };
+}
+
+/** The signed manifest served per (channel, platform, arch). */
+export interface IWso2UpdateManifest {
+	readonly schemaVersion: number;
+	readonly channel: string;
+	readonly platform: string;
+	readonly arch: string;
+	readonly sequence: number;
+	readonly publishedAt?: string;
+	readonly expiresAt?: string;
+	readonly app?: IWso2ManifestApp;
+	readonly components: readonly IWso2ManifestComponent[];
+	readonly recommendedSet?: IWso2RecommendedSet;
+}
+
+/** Per-component view used by the update flow and the Components UI. */
+export interface IWso2ComponentStatus {
+	readonly id: string;
+	readonly kind: Wso2ComponentKind;
+	readonly bundledVersion?: string;
+	/** Currently active version (override if installed, else bundled). */
+	readonly activeVersion?: string;
+	/** Newer version offered by the manifest, if any. */
+	readonly availableVersion?: string;
+	/** Version staged and awaiting a restart, if any. */
+	readonly pendingVersion?: string;
+	/** True when an installed override is active (i.e. not just the bundled version) and can be reverted. */
+	readonly overridden?: boolean;
+}
+
+/** A component update the client is offering to the user. */
+export interface IWso2AvailableUpdate {
+	readonly id: string;
+	readonly kind: Wso2ComponentKind;
+	readonly fromVersion?: string;
+	readonly toVersion: string;
+	readonly releaseNotesUrl?: string;
+}
+
+/** An extension VSIX that has been downloaded and verified, ready for the renderer to install. */
+export interface IWso2StagedExtension {
+	readonly id: string;
+	readonly version: string;
+	/** Absolute path to the verified VSIX on disk. */
+	readonly vsixPath: string;
+}
+
+/** A full-app update offered separately from component updates. */
+export interface IWso2AvailableAppUpdate {
+	readonly version: string;
+	readonly installerUrl: string;
+	readonly releaseNotesUrl?: string;
+}
+
+export const enum Wso2UpdateStateType {
+	Idle = 'idle',
+	CheckingForUpdates = 'checking',
+	UpdatesAvailable = 'available',
+	Downloading = 'downloading',
+	Downloaded = 'downloaded',
+	Error = 'error'
+}
+
+export type Wso2UpdateState =
+	| { readonly type: Wso2UpdateStateType.Idle }
+	| { readonly type: Wso2UpdateStateType.CheckingForUpdates; readonly explicit: boolean }
+	| { readonly type: Wso2UpdateStateType.UpdatesAvailable; readonly updates: readonly IWso2AvailableUpdate[]; readonly appUpdate?: IWso2AvailableAppUpdate }
+	| { readonly type: Wso2UpdateStateType.Downloading }
+	| { readonly type: Wso2UpdateStateType.Downloaded; readonly stagedExtensions: readonly IWso2StagedExtension[]; readonly restartRequired: boolean }
+	| { readonly type: Wso2UpdateStateType.Error; readonly message: string };
+
+/**
+ * Main-process service that discovers, verifies and stages component updates for
+ * WSO2 Integrator. It owns the local components manifest, downloads and verifies
+ * artifacts, stages runtime updates for activation at the next startup, and hands
+ * verified extension VSIXes to the renderer for installation. It never applies a
+ * silent update — the workbench UI drives download/apply on explicit user consent.
+ */
+export interface IWso2ComponentUpdateService {
+	readonly _serviceBrand: undefined;
+
+	readonly onStateChange: Event<Wso2UpdateState>;
+
+	/** The current aggregate update state (async so it works across the IPC proxy). */
+	getState(): Promise<Wso2UpdateState>;
+
+	/** Fetch and verify the manifest, then compute the offered updates. */
+	checkForUpdates(explicit: boolean): Promise<void>;
+
+	/**
+	 * Download and verify the offered updates (or the given subset). Runtime
+	 * components are staged and recorded as pending; extension VSIXes are staged
+	 * and returned via the resulting `Downloaded` state for the renderer to install.
+	 */
+	downloadUpdates(componentIds?: readonly string[]): Promise<void>;
+
+	/** Per-component bundled/active/available/pending view for the Components UI. */
+	getComponentStatuses(): Promise<IWso2ComponentStatus[]>;
+
+	/** Record that the renderer successfully installed a staged extension shadow copy. */
+	recordExtensionInstalled(id: string, version: string): Promise<void>;
+
+	/**
+	 * Reverts an active runtime override to its previous version (or the bundled version if
+	 * no previous override remains). Returns true if a revert was applied (requires restart).
+	 */
+	revertRuntimeOverride(id: string): Promise<boolean>;
+
+	/** Clears a component's active override record (used after the renderer uninstalls an extension shadow copy). */
+	clearComponentOverride(id: string): Promise<void>;
+
+	/** Open the full-app installer download for the current platform (notify + download flow). */
+	downloadAppInstaller(): Promise<void>;
+
+	/**
+	 * Applies a core-app update in place. On Windows this downloads and verifies the
+	 * editor-only update MSI and runs it silently (`msiexec /qn`) on quit, then relaunches
+	 * (§D8). On other platforms it falls back to {@link downloadAppInstaller}. Rejects if the
+	 * download or verification fails (so the caller can surface an error without quitting).
+	 */
+	applyAppUpdate(): Promise<void>;
+}
